{
  "name": "conversensus",
  "private": true,
  "workspaces": [
    "src/shared",
    "src/server",
    "src/client"
  ],
  "scripts": {
    "dev:server": "bun run --watch src/server/src/index.ts",
    "dev:client": "bun run --cwd src/client dev",
    "typecheck": "bun run --cwd src/client tsc --noEmit",
    "lint": "bun --bun biome check src/",
    "lint:fix": "bun --bun biome check --write src/",
    "setup": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo 'pre-commit hook installed'",
    "test": "bun test src/",
    "clear-pds-data": "bun run --cwd src/client scripts/clear-pds-data.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@happy-dom/global-registrator": "^20.8.4"
  }
}
